{"id":1,"name":"EV001","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":0,"tileId":0},"list":[{"code":221,"indent":0,"parameters":[]},{"code":241,"indent":0,"parameters":[{"name":"","volume":90,"pitch":100,"pan":0}]},{"code":230,"indent":0,"parameters":[60]},{"code":241,"indent":0,"parameters":[{"name":"MoldyVillage","volume":90,"pitch":90,"pan":0}]},{"code":231,"indent":0,"parameters":[1,"kanal",1,0,408,312,100,100,200,0]},{"code":222,"indent":0,"parameters":[]},{"code":230,"indent":0,"parameters":[60]},{"code":224,"indent":0,"parameters":[[80,0,0,170],30,true]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["The canal’s heart has stopped beating. Where once clear "]},{"code":401,"indent":0,"parameters":["water flowed, only filth remains. Villagers search in "]},{"code":401,"indent":0,"parameters":["vain for life’s source..."]},{"code":230,"indent":0,"parameters":[60]},{"code":224,"indent":0,"parameters":[[0,0,0,170],60,true]},{"code":230,"indent":0,"parameters":[60]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["Fields wither under a poisoned sky. Children fall ill. "]},{"code":401,"indent":0,"parameters":["Merchants close their stalls. A city’s spirit drowns in "]},{"code":401,"indent":0,"parameters":["its own neglect."]},{"code":230,"indent":0,"parameters":[60]},{"code":225,"indent":0,"parameters":[3,4,60,true]},{"code":250,"indent":0,"parameters":[{"name":"Thunder1","volume":90,"pitch":100,"pan":0}]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["No savior came. No gold could mend broken gears. "]},{"code":401,"indent":0,"parameters":["Hope, once